# =============================================================================
# Mini Platform API — Environment Variables
# =============================================================================

# REQUIRED — JWT signing secret
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# The application will refuse to start if this variable is not set.
JWT_SECRET_KEY=your-secret-key-here

# OPTIONAL — Upstash Redis for persistent, distributed rate limiting
# Without these, rate limiting falls back to in-memory (resets on restart,
# not suitable for multi-instance deployments).
#
# Get these values from https://console.upstash.com after creating a Redis database:
#   1. Create a new Redis database (free tier available)
#   2. Go to database details → REST API
#   3. Copy UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# =============================================================================
# Local development
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# Then start the server:
#   uvicorn src.main:app --reload
# =============================================================================
