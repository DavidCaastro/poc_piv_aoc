# Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secret-key-here

# Optional — Upstash Redis for persistent rate limiting across restarts
# Get these from https://console.upstash.com after creating a Redis database
# If not set, rate limiting falls back to in-memory (resets on restart)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here
